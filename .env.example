# Current validation collector
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
FOOTBALL_CUPS_DATA_DIR=
FOOTBALL_CUPS_BACKUP_DIR=
FOOTBALL_CUPS_OSS_BACKUP_DIR=
COLLECTOR_DISCOVERY_INTERVAL_MINUTES=30
COLLECTOR_REQUEST_MIN_INTERVAL_SECONDS=1.5
COLLECTOR_RUN_TIME_BUDGET_SECONDS=100
COLLECTOR_CLOCK_DRIFT_LIMIT_SECONDS=30

# Standardized database (optional when using the local D-drive runtime)
DATABASE_URL=

# Aliyun migration placeholders
ALIYUN_REGION=cn-hangzhou
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PREFIX=
ALIYUN_OSS_AUTH_MODE=EcsRamRole

# Future application stages
APP_ENV=development
ODDS_API_BASE_URL=
ODDS_API_KEY=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
